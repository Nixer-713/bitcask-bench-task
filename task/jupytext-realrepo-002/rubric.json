[
  {
    "id": "JTU001",
    "layer": "unit",
    "category": "parse_ipynb",
    "requirement_refs": ["REQ-notebook-model", "REQ-inspect"],
    "description": "inspect normalizes an ipynb notebook with missing ids, source arrays, supported metadata, execution counts, and outputs.",
    "weight": 4,
    "setup_files": {
      "nb.ipynb": "{\"nbformat\":4,\"metadata\":{\"kernelspec\":{\"name\":\"python3\"},\"minijupy\":{\"version\":3}},\"cells\":[{\"cell_type\":\"code\",\"source\":[\"x = 1\\n\",\"print(x)\\n\"],\"metadata\":{\"tags\":[\"run\"],\"name\":\"main\",\"drop\":true},\"execution_count\":7,\"outputs\":[{\"output_type\":\"stream\",\"text\":\"1\\n\"}]},{\"id\":\"note\",\"cell_type\":\"markdown\",\"source\":\"# Title\\n\",\"metadata\":{\"tags\":[\"doc\"]},\"outputs\":[{\"ignored\":true}]}]}"
    },
    "commands": [["inspect", "--input", "nb.ipynb"]],
    "checks": {
      "stdout_json_contains": {
        "0": {
          "ok": true,
          "command": "inspect",
          "format": "ipynb",
          "version": 3,
          "notebook": {
            "nbformat": 4,
            "nbformat_minor": 5,
            "cells": [
              {
                "id": "c1",
                "cell_type": "code",
                "source": "x = 1\nprint(x)\n",
                "metadata": {"tags": ["run"], "name": "main"},
                "execution_count": 7,
                "outputs": [{"output_type": "stream", "text": "1\n"}]
              },
              {
                "id": "note",
                "cell_type": "markdown",
                "source": "# Title\n",
                "metadata": {"tags": ["doc"]}
              }
            ]
          }
        }
      }
    }
  },
  {
    "id": "JTU002",
    "layer": "unit",
    "category": "parse_percent",
    "requirement_refs": ["REQ-percent-format", "REQ-version", "REQ-notebook-model", "REQ-inspect"],
    "description": "inspect parses percent headers, code/markdown/raw markers, ids, tags, names, and public version.",
    "weight": 4,
    "setup_files": {
      "script.py": "# ---\n# minijupy:\n#   formats: ipynb,py:percent\n#   version: 4\n# kernelspec:\n#   name: python3\n# ---\n# %% {\"id\":\"load\",\"tags\":[\"data\"],\"name\":\"loader\"}\nx = 1\n# %% [markdown] {\"id\":\"intro\",\"tags\":[\"doc\"]}\n# # Heading\n# text\n# %% [raw] {\"id\":\"raw1\"}\nraw text\n"
    },
    "commands": [["inspect", "--input", "script.py"]],
    "checks": {
      "stdout_json_contains": {
        "0": {
          "ok": true,
          "format": "py:percent",
          "version": 4,
          "notebook": {
            "metadata": {"kernelspec": {"name": "python3"}, "minijupy": {"formats": "ipynb,py:percent", "version": 4}},
            "cells": [
              {"id": "load", "cell_type": "code", "source": "x = 1\n", "metadata": {"tags": ["data"], "name": "loader"}},
              {"id": "intro", "cell_type": "markdown", "source": "# Heading\ntext\n", "metadata": {"tags": ["doc"]}},
              {"id": "raw1", "cell_type": "raw", "source": "raw text\n"}
            ]
          }
        }
      }
    }
  },
  {
    "id": "JTU003",
    "layer": "unit",
    "category": "write_percent_strip_outputs",
    "requirement_refs": ["REQ-convert", "REQ-percent-format", "REQ-output-preservation"],
    "description": "to-text writes percent markers and supported metadata while stripping outputs and execution counts.",
    "weight": 4,
    "setup_files": {
      "run.ipynb": "{\"nbformat\":4,\"nbformat_minor\":5,\"metadata\":{\"kernelspec\":{\"name\":\"python3\"},\"minijupy\":{\"formats\":\"ipynb,py:percent\",\"version\":2}},\"cells\":[{\"id\":\"run\",\"cell_type\":\"code\",\"source\":\"print(1)\\n\",\"metadata\":{\"tags\":[\"keep\"],\"name\":\"runner\"},\"execution_count\":9,\"outputs\":[{\"output_type\":\"stream\",\"text\":\"1\\n\"}]},{\"id\":\"md\",\"cell_type\":\"markdown\",\"source\":\"# Note\\n\",\"metadata\":{}}]}"
    },
    "commands": [["to-text", "--input", "run.ipynb", "--output", "run.py"]],
    "checks": {
      "file_exists": ["run.py"],
      "file_contains": {
        "run.py": ["minijupy:", "version: 2", "# %% {\"id\":\"run\"", "\"tags\":[\"keep\"]", "\"name\":\"runner\"", "# %% [markdown]"]
      },
      "file_not_contains": {
        "run.py": ["execution_count", "outputs", "1\\n\"}"]
      }
    }
  },
  {
    "id": "JTU004",
    "layer": "unit",
    "category": "same_directory_pair_path",
    "requirement_refs": ["REQ-pair-paths", "REQ-status"],
    "description": "status derives a same-directory missing percent counterpart for an ipynb file.",
    "weight": 3,
    "setup_files": {
      "demo.ipynb": "{\"nbformat\":4,\"metadata\":{\"minijupy\":{\"version\":1}},\"cells\":[{\"id\":\"a\",\"cell_type\":\"code\",\"source\":\"x=1\\n\",\"metadata\":{},\"execution_count\":null,\"outputs\":[]}]}"
    },
    "commands": [["status", "--input", "demo.ipynb"]],
    "checks": {
      "stdout_json_contains": {
        "0": {
          "ok": true,
          "pairs": [
            {
              "ipynb": "demo.ipynb",
              "text": "demo.py",
              "exists": {"ipynb": true, "text": false},
              "source": "ipynb",
              "missing": ["demo.py"]
            }
          ]
        }
      },
      "file_not_exists": ["demo.py"]
    }
  },
  {
    "id": "JTU005",
    "layer": "unit",
    "category": "directory_mapped_pair_path",
    "requirement_refs": ["REQ-files-config", "REQ-pair-paths", "REQ-status"],
    "description": "status uses notebook_dir/script_dir config to derive the paired path across directories.",
    "weight": 3,
    "setup_files": {
      "minijupy.toml": "formats = \"ipynb,py:percent\"\nnotebook_dir = \"notebooks\"\nscript_dir = \"scripts\"\n",
      "notebooks/a/demo.ipynb": "{\"nbformat\":4,\"metadata\":{\"minijupy\":{\"version\":1}},\"cells\":[{\"id\":\"a\",\"cell_type\":\"code\",\"source\":\"x=1\\n\",\"metadata\":{},\"execution_count\":null,\"outputs\":[]}]}"
    },
    "commands": [["status", "--input", "notebooks/a/demo.ipynb", "--config", "minijupy.toml"]],
    "checks": {
      "stdout_json_contains": {
        "0": {
          "pairs": [
            {
              "ipynb": "notebooks/a/demo.ipynb",
              "text": "scripts/a/demo.py",
              "missing": ["scripts/a/demo.py"],
              "source": "ipynb"
            }
          ]
        }
      },
      "file_not_exists": ["scripts/a/demo.py"]
    }
  },
  {
    "id": "JTU006",
    "layer": "unit",
    "category": "create_state_file",
    "requirement_refs": ["REQ-pair", "REQ-state-file", "REQ-version"],
    "description": "pair creates the percent counterpart and initializes .minijupy-state.json with paths and public versions.",
    "weight": 5,
    "setup_files": {
      "demo.ipynb": "{\"nbformat\":4,\"metadata\":{\"minijupy\":{\"version\":2}},\"cells\":[{\"id\":\"a\",\"cell_type\":\"code\",\"source\":\"x=1\\n\",\"metadata\":{},\"execution_count\":null,\"outputs\":[]}]}"
    },
    "commands": [["pair", "--input", "demo.ipynb"]],
    "checks": {
      "file_exists": ["demo.py", ".minijupy-state.json"],
      "file_json_contains_unordered": {
        ".minijupy-state.json": {
          "pairs": {
            "demo.ipynb": {
              "ipynb": "demo.ipynb",
              "text": "demo.py",
              "last_synced": {"ipynb_version": 2, "text_version": 2}
            }
          }
        }
      }
    }
  },
  {
    "id": "JTU007",
    "layer": "unit",
    "category": "detect_version_stale_text",
    "requirement_refs": ["REQ-status", "REQ-version", "REQ-state-file"],
    "description": "status detects that the text side is newer than the last synced state.",
    "weight": 4,
    "setup_files": {
      "demo.ipynb": "{\"nbformat\":4,\"metadata\":{\"minijupy\":{\"formats\":\"ipynb,py:percent\",\"version\":1}},\"cells\":[{\"id\":\"a\",\"cell_type\":\"code\",\"source\":\"x=1\\n\",\"metadata\":{},\"execution_count\":null,\"outputs\":[]}]}",
      "demo.py": "# ---\n# minijupy:\n#   formats: ipynb,py:percent\n#   version: 2\n# ---\n# %% {\"id\":\"a\"}\nx = 2\n",
      ".minijupy-state.json": "{\"pairs\":{\"demo.ipynb\":{\"ipynb\":\"demo.ipynb\",\"text\":\"demo.py\",\"last_synced\":{\"ipynb_version\":1,\"text_version\":1,\"ipynb_hash\":\"old\",\"text_hash\":\"old\"}}}}"
    },
    "commands": [["status", "--input", "demo.py"]],
    "checks": {
      "stdout_json_contains": {
        "0": {
          "pairs": [
            {
              "source": "text",
              "conflict": false,
              "versions": {"ipynb": 1, "text": 2, "last_ipynb": 1, "last_text": 1},
              "planned_writes": ["demo.ipynb", ".minijupy-state.json"]
            }
          ]
        }
      }
    }
  },
  {
    "id": "JTU008",
    "layer": "unit",
    "category": "detect_conflict",
    "requirement_refs": ["REQ-conflict", "REQ-status", "REQ-state-file"],
    "description": "status reports conflict when both sides have versions greater than the last synced versions.",
    "weight": 4,
    "setup_files": {
      "demo.ipynb": "{\"nbformat\":4,\"metadata\":{\"minijupy\":{\"formats\":\"ipynb,py:percent\",\"version\":2}},\"cells\":[{\"id\":\"a\",\"cell_type\":\"code\",\"source\":\"x=10\\n\",\"metadata\":{},\"execution_count\":null,\"outputs\":[]}]}",
      "demo.py": "# ---\n# minijupy:\n#   formats: ipynb,py:percent\n#   version: 2\n# ---\n# %% {\"id\":\"a\"}\nx = 20\n",
      ".minijupy-state.json": "{\"pairs\":{\"demo.ipynb\":{\"ipynb\":\"demo.ipynb\",\"text\":\"demo.py\",\"last_synced\":{\"ipynb_version\":1,\"text_version\":1,\"ipynb_hash\":\"old\",\"text_hash\":\"old\"}}}}"
    },
    "commands": [["status", "--input", "demo.ipynb"]],
    "checks": {
      "stdout_json_contains": {
        "0": {
          "pairs": [
            {
              "source": "none",
              "conflict": true,
              "versions": {"ipynb": 2, "text": 2, "last_ipynb": 1, "last_text": 1},
              "planned_writes": []
            }
          ],
          "summary": {"conflicts": 1}
        }
      }
    }
  },
  {
    "id": "JTU009",
    "layer": "unit",
    "category": "output_preservation_by_id",
    "requirement_refs": ["REQ-sync", "REQ-output-preservation"],
    "description": "sync --source text preserves outputs and execution_count by matching the public cell id.",
    "weight": 5,
    "setup_files": {
      "demo.ipynb": "{\"nbformat\":4,\"nbformat_minor\":5,\"metadata\":{\"minijupy\":{\"formats\":\"ipynb,py:percent\",\"version\":1}},\"cells\":[{\"id\":\"cell-a\",\"cell_type\":\"code\",\"source\":\"x = 1\\n\",\"metadata\":{},\"execution_count\":5,\"outputs\":[{\"output_type\":\"stream\",\"text\":\"old\\n\"}]}]}",
      "demo.py": "# ---\n# minijupy:\n#   formats: ipynb,py:percent\n#   version: 2\n# ---\n# %% {\"id\":\"cell-a\"}\nx = 2\n",
      ".minijupy-state.json": "{\"pairs\":{\"demo.ipynb\":{\"ipynb\":\"demo.ipynb\",\"text\":\"demo.py\",\"last_synced\":{\"ipynb_version\":1,\"text_version\":1,\"ipynb_hash\":\"old\",\"text_hash\":\"old\"}}}}"
    },
    "commands": [["sync", "--input", "demo.py", "--source", "text"]],
    "checks": {
      "file_json_contains_unordered": {
        "demo.ipynb": {
          "metadata": {"minijupy": {"version": 2}},
          "cells": [
            {"id": "cell-a", "source": "x = 2\n", "execution_count": 5, "outputs": [{"output_type": "stream", "text": "old\n"}]}
          ]
        },
        ".minijupy-state.json": {
          "pairs": {"demo.ipynb": {"last_synced": {"ipynb_version": 2, "text_version": 2}}}
        }
      }
    }
  },
  {
    "id": "JTU010",
    "layer": "unit",
    "category": "output_preservation_fallback",
    "requirement_refs": ["REQ-sync", "REQ-output-preservation"],
    "description": "sync --source text preserves outputs by same cell type and same source when ids differ.",
    "weight": 5,
    "setup_files": {
      "demo.ipynb": "{\"nbformat\":4,\"metadata\":{\"minijupy\":{\"formats\":\"ipynb,py:percent\",\"version\":1}},\"cells\":[{\"id\":\"old-id\",\"cell_type\":\"code\",\"source\":\"print(value)\\n\",\"metadata\":{},\"execution_count\":8,\"outputs\":[{\"output_type\":\"stream\",\"text\":\"42\\n\"}]}]}",
      "demo.py": "# ---\n# minijupy:\n#   formats: ipynb,py:percent\n#   version: 2\n# ---\n# %% {\"id\":\"new-id\"}\nprint(value)\n",
      ".minijupy-state.json": "{\"pairs\":{\"demo.ipynb\":{\"ipynb\":\"demo.ipynb\",\"text\":\"demo.py\",\"last_synced\":{\"ipynb_version\":1,\"text_version\":1,\"ipynb_hash\":\"old\",\"text_hash\":\"old\"}}}}"
    },
    "commands": [["sync", "--input", "demo.py", "--source", "text"]],
    "checks": {
      "file_json_contains_unordered": {
        "demo.ipynb": {
          "cells": [
            {"id": "new-id", "cell_type": "code", "source": "print(value)\n", "execution_count": 8, "outputs": [{"output_type": "stream", "text": "42\n"}]}
          ]
        }
      }
    }
  },
  {
    "id": "JTU011",
    "layer": "unit",
    "category": "status_single_pair",
    "requirement_refs": ["REQ-status", "REQ-invariants"],
    "description": "status reports a clean pair with source none and no planned writes.",
    "weight": 4,
    "setup_files": {
      "demo.ipynb": "{\"nbformat\":4,\"metadata\":{\"minijupy\":{\"formats\":\"ipynb,py:percent\",\"version\":1}},\"cells\":[{\"id\":\"a\",\"cell_type\":\"code\",\"source\":\"x=1\\n\",\"metadata\":{},\"execution_count\":null,\"outputs\":[]}]}",
      "demo.py": "# ---\n# minijupy:\n#   formats: ipynb,py:percent\n#   version: 1\n# ---\n# %% {\"id\":\"a\"}\nx=1\n",
      ".minijupy-state.json": "{\"pairs\":{\"demo.ipynb\":{\"ipynb\":\"demo.ipynb\",\"text\":\"demo.py\",\"last_synced\":{\"ipynb_version\":1,\"text_version\":1,\"ipynb_hash\":\"h1\",\"text_hash\":\"h1\"}}}}"
    },
    "commands": [["status", "--input", "demo.ipynb"]],
    "checks": {
      "stdout_json_contains": {
        "0": {
          "pairs": [{"source": "none", "conflict": false, "planned_writes": [], "errors": []}],
          "summary": {"pairs": 1, "conflicts": 0, "missing": 0, "planned_writes": 0, "errors": 0}
        }
      }
    }
  },
  {
    "id": "JTU012",
    "layer": "unit",
    "category": "check_single_pair",
    "requirement_refs": ["REQ-check", "REQ-convert", "REQ-invariants"],
    "description": "check reports roundtrip_ok for a representable clean pair and writes no files.",
    "weight": 4,
    "setup_files": {
      "demo.ipynb": "{\"nbformat\":4,\"metadata\":{\"minijupy\":{\"formats\":\"ipynb,py:percent\",\"version\":1}},\"cells\":[{\"id\":\"a\",\"cell_type\":\"code\",\"source\":\"x=1\\n\",\"metadata\":{\"tags\":[\"t\"],\"name\":\"n\"},\"execution_count\":null,\"outputs\":[]},{\"id\":\"m\",\"cell_type\":\"markdown\",\"source\":\"hello\\n\",\"metadata\":{}}]}",
      "demo.py": "# ---\n# minijupy:\n#   formats: ipynb,py:percent\n#   version: 1\n# ---\n# %% {\"id\":\"a\",\"tags\":[\"t\"],\"name\":\"n\"}\nx=1\n# %% [markdown] {\"id\":\"m\"}\n# hello\n",
      ".minijupy-state.json": "{\"pairs\":{\"demo.ipynb\":{\"ipynb\":\"demo.ipynb\",\"text\":\"demo.py\",\"last_synced\":{\"ipynb_version\":1,\"text_version\":1,\"ipynb_hash\":\"h\",\"text_hash\":\"h\"}}}}"
    },
    "commands": [["check", "--input", "demo.py"]],
    "checks": {
      "stdout_json_contains": {
        "0": {
          "command": "check",
          "pairs": [{"roundtrip_ok": true, "differences": [], "errors": []}],
          "summary": {"errors": 0}
        }
      },
      "file_exists": [".minijupy-state.json", "demo.ipynb"]
    }
  },
  {
    "id": "JTU013",
    "layer": "unit",
    "category": "malformed_percent_atomicity",
    "requirement_refs": ["REQ-percent-format", "REQ-error-atomic"],
    "description": "Malformed percent marker JSON fails without creating the requested ipynb output.",
    "weight": 4,
    "setup_files": {"bad.py": "# %% {bad json}\nprint('bad')\n"},
    "commands": [{"args": ["to-ipynb", "--input", "bad.py", "--output", "bad.ipynb"], "expect_error": true}],
    "checks": {"file_not_exists": ["bad.ipynb", ".minijupy-state.json"]}
  },
  {
    "id": "JTU014",
    "layer": "unit",
    "category": "malformed_ipynb_atomicity",
    "requirement_refs": ["REQ-notebook-model", "REQ-error-atomic"],
    "description": "Malformed ipynb JSON fails without creating the requested percent output.",
    "weight": 4,
    "setup_files": {"bad.ipynb": "{\"nbformat\":4,\"cells\":["},
    "commands": [{"args": ["to-text", "--input", "bad.ipynb", "--output", "bad.py"], "expect_error": true}],
    "checks": {"file_not_exists": ["bad.py", ".minijupy-state.json"]}
  },
  {
    "id": "JTU015",
    "layer": "unit",
    "category": "paths_command",
    "requirement_refs": ["REQ-paths", "REQ-pair-paths", "REQ-error-atomic"],
    "description": "paths reports the paired ipynb/text paths and existence flags without parsing or writing counterparts.",
    "weight": 3,
    "setup_files": {
      "minijupy.toml": "formats = \"ipynb,py:percent\"\nnotebook_dir = \"notebooks\"\nscript_dir = \"scripts\"\n",
      "notebooks/demo.ipynb": "{\"nbformat\":4,\"cells\":[{\"cell_type\":\"code\",\"source\":\"x=1\\n\"}]}"
    },
    "commands": [["paths", "--input", "notebooks/demo.ipynb", "--config", "minijupy.toml"]],
    "checks": {
      "stdout_json_contains": {
        "0": {
          "ok": true,
          "command": "paths",
          "input": "notebooks/demo.ipynb",
          "ipynb": "notebooks/demo.ipynb",
          "text": "scripts/demo.py",
          "exists": {"ipynb": true, "text": false}
        }
      },
      "file_not_exists": ["scripts/demo.py", ".minijupy-state.json"]
    }
  },
  {
    "id": "JTU016",
    "layer": "unit",
    "category": "to_ipynb_update_preserves_outputs",
    "requirement_refs": ["REQ-convert", "REQ-output-preservation", "REQ-notebook-model"],
    "description": "to-ipynb --update reads inputs from text while preserving matching outputs from the existing ipynb output.",
    "weight": 5,
    "setup_files": {
      "demo.py": "# ---\n# minijupy:\n#   formats: ipynb,py:percent\n#   version: 2\n# ---\n# %% {\"id\":\"calc\",\"tags\":[\"run\"]}\nanswer = 43\n",
      "demo.ipynb": "{\"nbformat\":4,\"metadata\":{\"minijupy\":{\"formats\":\"ipynb,py:percent\",\"version\":1}},\"cells\":[{\"id\":\"calc\",\"cell_type\":\"code\",\"source\":\"answer = 42\\n\",\"metadata\":{\"tags\":[\"old\"]},\"execution_count\":6,\"outputs\":[{\"output_type\":\"execute_result\",\"data\":{\"text/plain\":\"42\"}}]}]}"
    },
    "commands": [["to-ipynb", "--input", "demo.py", "--output", "demo.ipynb", "--update"]],
    "checks": {
      "file_json_contains_unordered": {
        "demo.ipynb": {
          "metadata": {"minijupy": {"version": 2}},
          "cells": [
            {
              "id": "calc",
              "source": "answer = 43\n",
              "metadata": {"tags": ["run"]},
              "execution_count": 6,
              "outputs": [{"data": {"text/plain": "42"}}]
            }
          ]
        }
      },
      "file_not_exists": [".minijupy-state.json"]
    }
  },
  {
    "id": "JTS001",
    "layer": "system",
    "category": "pair_status_sync_clean_loop",
    "system_dimension": "pair_status_sync_clean_loop",
    "requirement_refs": ["REQ-pair", "REQ-state-file", "REQ-status", "REQ-sync", "REQ-invariants"],
    "description": "A notebook can be paired, reported as clean, synced as a no-op, and then reported clean again.",
    "weight": 7,
    "setup_files": {
      "demo.ipynb": "{\"nbformat\":4,\"metadata\":{\"minijupy\":{\"version\":1}},\"cells\":[{\"id\":\"a\",\"cell_type\":\"code\",\"source\":\"x=1\\n\",\"metadata\":{},\"execution_count\":null,\"outputs\":[]}]}"
    },
    "commands": [
      ["pair", "--input", "demo.ipynb"],
      ["status", "--input", "demo.ipynb"],
      ["sync", "--input", "demo.ipynb"],
      ["status", "--input", "demo.py"]
    ],
    "checks": {
      "file_exists": ["demo.py", ".minijupy-state.json"],
      "stdout_json_contains": {
        "1": {"pairs": [{"source": "none", "conflict": false, "planned_writes": []}]},
        "3": {"pairs": [{"source": "none", "conflict": false, "planned_writes": []}], "summary": {"planned_writes": 0}}
      }
    }
  },
  {
    "id": "JTS002",
    "layer": "system",
    "category": "edit_text_status_sync_notebook_updated",
    "system_dimension": "text_edit_sync_updates_notebook",
    "requirement_refs": ["REQ-version", "REQ-status", "REQ-sync", "REQ-state-file"],
    "description": "A newer text side is reported as source text; sync updates the notebook and state; status is clean afterwards.",
    "weight": 8,
    "setup_files": {
      "demo.ipynb": "{\"nbformat\":4,\"metadata\":{\"minijupy\":{\"formats\":\"ipynb,py:percent\",\"version\":1}},\"cells\":[{\"id\":\"a\",\"cell_type\":\"code\",\"source\":\"x=1\\n\",\"metadata\":{},\"execution_count\":null,\"outputs\":[]}]}",
      "demo.py": "# ---\n# minijupy:\n#   formats: ipynb,py:percent\n#   version: 2\n# ---\n# %% {\"id\":\"a\"}\nx=2\n",
      ".minijupy-state.json": "{\"pairs\":{\"demo.ipynb\":{\"ipynb\":\"demo.ipynb\",\"text\":\"demo.py\",\"last_synced\":{\"ipynb_version\":1,\"text_version\":1,\"ipynb_hash\":\"h1\",\"text_hash\":\"h1\"}}}}"
    },
    "commands": [
      ["status", "--input", "demo.py"],
      ["sync", "--input", "demo.py"],
      ["status", "--input", "demo.ipynb"]
    ],
    "checks": {
      "stdout_json_contains": {
        "0": {"pairs": [{"source": "text", "planned_writes": ["demo.ipynb", ".minijupy-state.json"]}]},
        "2": {"pairs": [{"source": "none", "planned_writes": []}]}
      },
      "file_json_contains_unordered": {
