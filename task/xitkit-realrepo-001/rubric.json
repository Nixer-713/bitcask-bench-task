[
  {
    "id": "XITU001",
    "layer": "unit",
    "category": "parse_statuses",
    "requirement_refs": [
      "REQ-parse-status",
      "REQ-list"
    ],
    "description": "Parses all five public checkbox statuses.",
    "weight": 4,
    "setup_files": {
      "tasks.xit": "[ ] Open item\n[x] Done item\n[@] Doing item\n[~] Old item\n[?] Question item\n"
    },
    "commands": [
      [
        "list",
        "--file",
        "tasks.xit"
      ]
    ],
    "checks": {
      "stdout_json_contains": {
        "0": [
          {
            "id": 1,
            "status": "open",
            "description": "Open item"
          },
          {
            "id": 2,
            "status": "done",
            "description": "Done item"
          },
          {
            "id": 3,
            "status": "ongoing",
            "description": "Doing item"
          },
          {
            "id": 4,
            "status": "obsolete",
            "description": "Old item"
          },
          {
            "id": 5,
            "status": "question",
            "description": "Question item"
          }
        ]
      },
      "stdout_json_length": {
        "0": 5
      }
    }
  },
